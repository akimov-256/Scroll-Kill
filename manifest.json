{
    "name": "Scroll Kill",
    "version": "0.0.1",
    "manifest_version": 3,
    "description": "Blocks instagram reels in feed",
    "permissions": [ "storage" ],
    "content_scripts": [
        {
            "matches": ["*://*.instagram.com/*"],
            "js": ["./scripts/contentScript.js"]
        }
    ],
    "background": {
        "service_worker": "scripts/background.js"
    },
    "action": {
        "default_title": "Scroll Kill",
        "default_popup": "popup.html"
    }
}